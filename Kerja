CREATE DATABASE db_kerja;
USE db_kerja;

-- Tabel untuk menyimpan data utama
CREATE TABLE data_kerja (
    id INT AUTO_INCREMENT PRIMARY KEY,
    kategori ENUM('reset_sandi', 'wd_pending', 'bukti_transfer', 'memo_keep'),
    isi_data TEXT NOT NULL,
    lampiran_file VARCHAR(255) NULL,
    tanggal TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
